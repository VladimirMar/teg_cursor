{
  "name": "teg_financ",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "api": "node --env-file=.env server.js",
    "api:fresh": "node --env-file=.env scripts/start-local-api.mjs",
    "dev": "vite",
    "dev:full": "concurrently \"npm run api\" \"npm run dev -- --host 0.0.0.0 --port 5173 --strictPort\"",
    "build": "tsc -b && vite build",
    "homol:build": "tsc -b && vite build --mode homolog && node scripts/build-homologation.mjs",
    "homol:publish": "powershell -ExecutionPolicy Bypass -File .\\publicar-homologacao.ps1",
    "homol:api": "node scripts/start-homologation-api.mjs",
    "homol:web": "node scripts/homologation-web-server.mjs",
    "homol:url": "powershell -ExecutionPolicy Bypass -File .\\scripts\\show-homologation-urls.ps1",
    "homol:repair-config": "node scripts/homologation-control/repair-homologation-reference-data.mjs",
    "homol:prepare-smoke": "node scripts/homologation-control/prepare-homologation-smoke-data.mjs",
    "homol:smoke": "set API_BASE_URL=http://127.0.0.1:3002&& node scripts/smoke-api.mjs all",
    "homol:smoke:with-prepare": "node scripts/homologation-control/prepare-homologation-smoke-data.mjs --run-smoke",
    "homol:start": "powershell -ExecutionPolicy Bypass -File .\\iniciar-homologacao.ps1",
    "homol:stop": "powershell -ExecutionPolicy Bypass -File .\\parar-homologacao.ps1",
    "lint": "eslint .",
    "preview": "vite preview",
    "import:xml:all": "node scripts/import-all-xml.mjs",
    "validate:ordem-servico:xml": "node scripts/validate-ordem-servico-xml.mjs",
    "import:ordem-servico": "node scripts/import-ordem-servico.mjs",
    "import:ordem-servico:background": "node scripts/import-ordem-servico-background.mjs",
    "pipeline:ordem-servico": "node scripts/pipeline-ordem-servico.mjs",
    "verify:invalid-fixtures": "node scripts/verify-invalid-fixtures.mjs all",
    "verify:invalid-fixtures:condutor": "node scripts/verify-invalid-fixtures.mjs condutor",
    "verify:invalid-fixtures:credenciada": "node scripts/verify-invalid-fixtures.mjs credenciada",
    "verify:invalid-fixtures:veiculo": "node scripts/verify-invalid-fixtures.mjs veiculo",
    "verify:credenciada:ceps": "node scripts/verify-credenciada-ceps.mjs",
    "smoke:api": "node scripts/smoke-api.mjs all",
    "smoke:api:documental": "node scripts/smoke-api.mjs documental",
    "verify:apontamento-servicos:filters": "node scripts/verify-apontamento-servicos-filters.mjs",
    "verify:apontamento-servicos:ordering": "node scripts/verify-apontamento-servicos-ordering.mjs",
    "verify:apontamento-servicos:negative-import": "node scripts/verify-apontamento-servicos-negative-import.mjs",
    "seed:condicao:dev": "node scripts/seed-condicao-dev.mjs",
    "recalculate:termo-values": "node scripts/recalculate-termo-values.mjs",
    "smoke:api:condutor": "node scripts/smoke-api.mjs condutor",
    "smoke:api:monitor": "node scripts/smoke-api.mjs monitor",
    "smoke:api:credenciada": "node scripts/smoke-api.mjs credenciada",
    "homol:smoke:documental": "set API_BASE_URL=http://127.0.0.1:3002&& node scripts/smoke-api.mjs documental",
    "smoke:api:ordem-servico": "node scripts/smoke-api.mjs ordem-servico",
    "smoke:api:apontamento-servicos": "node scripts/smoke-api.mjs apontamento-servicos",
    "smoke:api:apuracao-status-transition": "node scripts/smoke-api.mjs apuracao-status-transition",
    "smoke:api:veiculo": "node scripts/smoke-api.mjs veiculo",
    "smoke:api:marca-modelo": "node scripts/smoke-api.mjs marca-modelo",
    "smoke:api:remuneracao-formula": "node scripts/verify-remuneracao-formula.mjs",
    "verify:remuneracao:formula": "node scripts/verify-remuneracao-formula.mjs",
    "smoke:api:remuneracao:km-continua": "node scripts/verify-remuneracao-km-continua.mjs",
    "verify:remuneracao:km-continua": "node scripts/verify-remuneracao-km-continua.mjs",
    "verify:apuracao:status-transition": "node scripts/verify-apuracao-status-transition.mjs"
  },
  "dependencies": {
    "fast-xml-parser": "^5.5.10",
    "jszip": "^3.10.1",
    "pg": "^8.20.0",
    "react": "19",
    "react-dom": "19",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
